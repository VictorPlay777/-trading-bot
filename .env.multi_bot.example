# Multi-Bot API Keys Configuration
# Copy this file to .env and fill in your keys

# Bot 1 - Aggressive Strategy (High leverage, high risk)
BYBIT_API_KEY_1=your_main_account_api_key
BYBIT_API_SECRET_1=your_main_account_secret

# Bot 2 - Conservative Strategy (Low leverage, testnet recommended)
BYBIT_API_KEY_2=your_testnet_or_secondary_key
BYBIT_API_SECRET_2=your_testnet_or_secondary_secret

# Bot 3 - Alts Specialist (Separate account for altcoins)
BYBIT_API_KEY_3=your_alts_account_key
BYBIT_API_SECRET_3=your_alts_account_secret

# Additional bots can use keys 4, 5, etc.
# BYBIT_API_KEY_4=...
# BYBIT_API_SECRET_4=...
